<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Welcome</title>

<style>
    body {
        margin: 0;
        overflow: hidden;
        background: black;
        font-family: Arial, sans-serif;
    }

    .msg {
        position: absolute;
        color: red;
        font-size: 40px;
        font-weight: bold;
        animation: float 5s linear infinite;
        text-shadow: 0 0 10px red, 0 0 20px white;
    }

    @keyframes float {
        0% {
            transform: translateY(100vh) scale(0.5);
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
        100% {
            transform: translateY(-100px) scale(1.2);
            opacity: 0;
        }
    }
</style>
</head>

<body>

<script>
function createMessage() {
    const msg = document.createElement("div");
    msg.className = "msg";
    msg.innerText = "FUCK OFF";

    // random horizontal position
    msg.style.left = Math.random() * window.innerWidth + "px";

    // random size
    msg.style.fontSize = (30 + Math.random() * 50) + "px";

    document.body.appendChild(msg);

    // remove after animation
    setTimeout(() => {
        msg.remove();
    }, 5000);
}

// create messages continuously
setInterval(createMessage, 500);
</script>

</body>
</html>
